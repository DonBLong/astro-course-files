---
import Section from "@/components/portfolio/home/Section.astro";
import ProjectsList from "@/components/portfolio/projects/ProjectList.astro";
import ButtonLink from "@/components/ui/ButtonLink.astro";
import H2 from "@/components/ui/typography/H2.astro";
---

<Section aria-labelledby="#recent-projects">
  <div class="flex justify-between flex-wrap items-center">
    <H2 id="recent-projects">Recent Projects</H2>
    <ButtonLink
      variant="outline"
      href="/portfolio/projects"
      class="justify-self-center">See All Projects</ButtonLink>
  </div>
  <ProjectsList limit={3} />
</Section>
