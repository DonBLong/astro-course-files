---
import PostList from "@/components/portfolio/blog/PostList.astro";
import Section from "@/components/portfolio/home/Section.astro";
import ButtonLink from "@/components/ui/ButtonLink.astro";
import H2 from "@/components/ui/typography/H2.astro";
---

<Section aria-labelledby="#latest-posts">
  <div class="flex justify-between flex-wrap items-center">
    <H2 id="latest-posts">Latest Posts</H2>
    <ButtonLink
      variant="outline"
      href="/portfolio/blog"
      class="justify-self-center">See Full Blog</ButtonLink>
  </div>
  <PostList limit={3} />
</Section>
