---
import { cn } from "@/utils/cn";
import type { HTMLAttributes } from "astro/types";

type Props = HTMLAttributes<"blockquote">;

const { class: className, "class:list": classList, ...props } = Astro.props;
---

<blockquote
  class={cn(
    "mt-6 border-l-2 pl-6 italic",
    className,
    classList,
  )}
  {...props}>
  <slot />
</blockquote>
