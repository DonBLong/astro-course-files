---
import { cn } from "@/utils/cn";
import type { HTMLAttributes } from "astro/types";

type Props = HTMLAttributes<"p">;

const { class: className, "class:list": classList, ...props } = Astro.props;
---

<p
  class={cn(
    "text-muted-foreground text-xl",
    className,
    classList,
  )}
  {...props}>
  <slot />
</p>
