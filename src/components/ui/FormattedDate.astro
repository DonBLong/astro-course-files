---
import { cn } from "@/utils/cn";
import type { HTMLAttributes } from "astro/types";

interface Props extends HTMLAttributes<"time"> {
  date: Date;
}

const { date, class: className, "class:list": classList, ...props } =
  Astro.props;
---

<time
  datetime={date.toISOString()}
  class={cn("uppercase", className, classList)}
  {...props}>{date.toLocaleDateString("en", { dateStyle: "long" })}</time>
